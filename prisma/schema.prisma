generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  TECHNICIAN
  FINANCE
  SALES
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
  BLOCKED
}

enum AddressType {
  BILLING
  SERVICE
  DELIVERY
  HEADQUARTER
  OTHER
}

enum ClientType {
  INDIVIDUAL
  COMPANY
}

enum ServiceOrderStatus {
  DRAFT
  OPEN
  SCHEDULED
  IN_PROGRESS
  WAITING_PARTS
  WAITING_APPROVAL
  COMPLETED
  CANCELED
}

enum ServiceOrderPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
  RESERVATION
  RETURN
}

enum FinancialStatus {
  OPEN
  PAID
  OVERDUE
  CANCELED
  PARTIAL
}

enum ReceivableStatus {
  PLANNED
  PENDING
  PARTIALLY_RECEIVED
  RECEIVED
  OVERDUE
  RENEGOTIATED
  CANCELED
  REVERSED
}

enum CashFlowType {
  INCOME
  EXPENSE
}

enum BudgetStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CANCELED
}

enum ContractStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
  CANCELED
}

enum PreventiveStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELED
}

enum MaintenanceFrequencyType {
  DAYS
  WEEKS
  MONTHS
  YEARS
  OPERATING_HOURS
  CUSTOM
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
}

enum FileVisibility {
  PRIVATE
  COMPANY
  PUBLIC
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

enum ToolStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  LOST
}

enum AssetStatus {
  ACTIVE
  IN_MAINTENANCE
  LOST
  SOLD
  DISCARDED
  INACTIVE
}

enum AssetCondition {
  NEW
  EXCELLENT
  GOOD
  REGULAR
  POOR
  DAMAGED
}

model Empresa {
  id        String    @id @default(cuid())
  companyId String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name         String
  legalName    String?
  document     String? @unique
  email        String?
  phone        String?
  tradeSegment String?
  active       Boolean @default(true)

  usuarios               Usuario[]
  permissoes             Permissao[]
  clientes               Cliente[]
  enderecos              Endereco[]
  equipamentos           Equipamento[]
  equipamentosInstalados EquipamentoInstalado[]
  fornecedores           Fornecedor[]
  veiculos               Veiculo[]
  ferramentas            Ferramenta[]
  estoques               Estoque[]
  categorias             Categoria[]
  produtos               Produto[]
  movimentacoesEstoque   MovimentacaoEstoque[]
  ordensServico          OrdemServico[]
  checklists             Checklist[]
  fotos                  Foto[]
  checklistTemplates     ChecklistTemplate[] @relation("ChecklistTemplatesCompany")
  checklistTemplateItems ChecklistTemplateItem[] @relation("ChecklistTemplateItemsCompany")
  assinaturas            Assinatura[]
  materiaisUtilizados    MaterialUtilizado[]
  equipes                Equipe[]
  agendas                Agenda[]
  financeiros            Financeiro[]
  contasReceber          ContaReceber[]
  contasPagar            ContaPagar[]
  fluxosCaixa            FluxoCaixa[]
  centrosCusto           CentroCusto[]
  orcamentos             Orcamento[]
  contratos              Contrato[]
  manutencoesPreventivas ManutencaoPreventiva[]
  notificacoes           Notificacao[]
  logsSistema            LogSistema[]
  arquivos               Arquivo[]
  configuracaoEmpresa    ConfiguracaoEmpresa?
  categoriasFinanceiras  FinancialCategory[]
  contasFinanceiras      FinancialAccount[]
  transacoesFinanceiras  FinancialTransaction[]
  categoriasPatrimoniais AssetCategory[]
  patrimonios            Asset[]
  equipamentosHistorico   EquipmentServiceHistory[]
  serviceOrderChecklists   ServiceOrderChecklist[] @relation("ServiceOrderChecklistsCompany")
  serviceOrderChecklistItems ServiceOrderChecklistItem[] @relation("ServiceOrderChecklistItemsCompany")
  serviceOrderAttachments ServiceOrderAttachment[] @relation("ServiceOrderAttachmentsCompany")
  serviceOrderAcceptances ServiceOrderAcceptance[] @relation("ServiceOrderAcceptancesCompany")
  warranties               Warranty[]              @relation("CompanyWarranties")

  @@index([name])
  @@index([deletedAt])
  @@map("empresas")
}

enum ChecklistCategory {
  INSTALLATION
  PREVENTIVE_MAINTENANCE
  CORRECTIVE_MAINTENANCE
  CLEANING
  ELECTRICAL_INSPECTION
  SAFETY
  COMMISSIONING
  WARRANTY
  OTHER
}

enum ChecklistItemType {
  BOOLEAN
  TEXT
  LONG_TEXT
  NUMBER
  DECIMAL
  DATE
  TIME
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  MEASUREMENT
  PHOTO_REQUIRED
  SIGNATURE_REQUIRED
  SECTION
  INFORMATION
}

enum ServiceOrderChecklistStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum ServiceOrderAttachmentType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  SIGNATURE
  RECEIPT
  INVOICE
  REPORT
  OTHER
}

enum ServiceOrderAttachmentCategory {
  BEFORE_SERVICE
  DURING_SERVICE
  AFTER_SERVICE
  DIAGNOSIS
  EQUIPMENT
  INSTALLATION
  CHECKLIST
  CUSTOMER_SIGNATURE
  TECHNICAL_REPORT
  WARRANTY
  PAYMENT
  GENERAL
}

enum ServiceOrderAcceptanceType {
  SERVICE_AUTHORIZATION
  SERVICE_COMPLETION
  TECHNICAL_REPORT
  WARRANTY_TERMS
  BUDGET_APPROVAL
  EQUIPMENT_DELIVERY
  OTHER
}

enum ServiceOrderAcceptanceStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELED
}

enum WarrantyProviderType {
  COMPANY
  MANUFACTURER
  SUPPLIER
  THIRD_PARTY
}

enum WarrantyType {
  INSTALLATION
  SERVICE
  LABOR
  PART
  EQUIPMENT
  FULL
  OTHER
}

enum WarrantyStatus {
  ACTIVE
  EXPIRED
  VOID
  CANCELED
}

enum StorageProvider {
  SUPABASE
  LOCAL
  S3
  GOOGLE_DRIVE
  OTHER
}

model ServiceOrderAttachment {
  id                        String   @id @default(cuid())
  companyId                 String
  serviceOrderId            String
  serviceOrderChecklistId   String?
  serviceOrderChecklistItemId String?
  uploadedByUserId          String?
  attachmentType            ServiceOrderAttachmentType
  category                  ServiceOrderAttachmentCategory
  fileName                  String
  originalFileName          String?
  mimeType                  String
  fileSizeBytes             BigInt?  @db.BigInt
  storageProvider           StorageProvider
  storageBucket             String?
  storagePath               String
  publicUrl                 String?
  checksum                  String?
  title                     String?
  description               String?
  capturedAt                DateTime?
  latitude                  Decimal? @db.Decimal(10,7)
  longitude                 Decimal? @db.Decimal(10,7)
  sortOrder                 Int?
  isCustomerVisible         Boolean  @default(false)
  isRequiredRecord          Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  company                   Empresa                    @relation("ServiceOrderAttachmentsCompany", fields: [companyId], references: [id])
  serviceOrder              OrdemServico               @relation("ServiceOrderAttachmentsOrder", fields: [serviceOrderId], references: [id])
  serviceOrderChecklist     ServiceOrderChecklist?     @relation("ServiceOrderAttachmentsChecklist", fields: [serviceOrderChecklistId], references: [id])
  serviceOrderChecklistItem ServiceOrderChecklistItem? @relation("ServiceOrderAttachmentsChecklistItem", fields: [serviceOrderChecklistItemId], references: [id])
  uploadedBy                Usuario?                   @relation("UploadedServiceOrderAttachments", fields: [uploadedByUserId], references: [id])
  serviceOrderAcceptance   ServiceOrderAcceptance?    @relation("ServiceOrderAcceptanceAttachment")

  @@index([companyId, serviceOrderId])
  @@index([companyId, serviceOrderChecklistId])
  @@index([companyId, serviceOrderChecklistItemId])
  @@index([companyId, uploadedByUserId])
  @@index([companyId, attachmentType])
  @@index([companyId, category])
  @@index([companyId, capturedAt])
  @@index([companyId, isCustomerVisible])
  @@index([companyId, deletedAt])
  @@index([companyId, checksum])
  @@index([serviceOrderId, sortOrder])
  @@map("service_order_attachments")
}

model ServiceOrderAcceptance {
  id                      String                        @id @default(cuid())
  companyId               String
  serviceOrderId          String
  clientId                String
  attachmentId            String?
  acceptanceType          ServiceOrderAcceptanceType  @default(SERVICE_COMPLETION)
  status                  ServiceOrderAcceptanceStatus @default(PENDING)
  signerName              String
  signerDocument          String?
  signerEmail             String?
  signerPhone             String?
  acceptedAt              DateTime?
  rejectedAt              DateTime?
  acceptanceTextSnapshot  String
  termsVersion            String?
  ipAddress               String?
  userAgent               String?
  latitude                Decimal?                     @db.Decimal(10,7)
  longitude               Decimal?                     @db.Decimal(10,7)
  rejectionReason         String?
  notes                   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  company         Empresa                @relation("ServiceOrderAcceptancesCompany", fields: [companyId], references: [id])
  serviceOrder    OrdemServico           @relation("ServiceOrderAcceptancesOrder", fields: [serviceOrderId], references: [id])
  client          Cliente                @relation("ServiceOrderAcceptancesClient", fields: [clientId], references: [id])
  attachment      ServiceOrderAttachment? @relation("ServiceOrderAcceptanceAttachment", fields: [attachmentId], references: [id])

  @@unique([attachmentId])
  @@index([companyId, serviceOrderId])
  @@index([companyId, clientId])
  @@index([companyId, status])
  @@index([companyId, acceptanceType])
  @@index([companyId, acceptedAt])
  @@index([companyId, rejectedAt])
  @@index([companyId, deletedAt])
  @@map("service_order_acceptances")
}

model Warranty {
  id                   String              @id @default(cuid())
  companyId            String
  clientId             String
  serviceOrderId       String?
  installedEquipmentId String?
  technicalReportId    String?
  providerType         WarrantyProviderType
  warrantyType         WarrantyType
  status               WarrantyStatus
  title                String
  description          String
  startDate            DateTime
  endDate              DateTime
  coverageDescription  String
  exclusions           String
  supplierName         String?
  manufacturerName     String?
  invoiceNumber        String?
  notes                String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  company            Empresa               @relation("CompanyWarranties", fields: [companyId], references: [id])
  client             Cliente               @relation("ClientWarranties", fields: [clientId], references: [id])
  serviceOrder       OrdemServico?         @relation("ServiceOrderWarrantiesOrder", fields: [serviceOrderId], references: [id])
  installedEquipment EquipamentoInstalado? @relation("EquipmentWarrantiesInstalledEquipment", fields: [installedEquipmentId], references: [id])

  /// technicalReportId is a future optional link to a ServiceOrderTechnicalReport model

  @@index([companyId, status])
  @@index([companyId, warrantyType])
  @@index([companyId, providerType])
  @@index([companyId, clientId])
  @@index([companyId, installedEquipmentId])
  @@index([companyId, serviceOrderId])
  @@index([companyId, endDate])
  @@index([companyId, deletedAt])
  @@map("warranties")
}

model ServiceOrderChecklist {
  id                    String   @id @default(cuid())
  companyId             String
  serviceOrderId        String
  checklistTemplateId   String
  checklistTemplateVersion Int
  assignedToUserId      String?
  startedAt             DateTime?
  completedAt           DateTime?
  status                ServiceOrderChecklistStatus @default(PENDING)
  notes                 String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  deletedAt             DateTime?

  company       Empresa        @relation("ServiceOrderChecklistsCompany", fields: [companyId], references: [id])
  serviceOrder  OrdemServico   @relation("ServiceOrderChecklistsOrder", fields: [serviceOrderId], references: [id])
  checklistTemplate ChecklistTemplate @relation("ServiceOrderChecklistsTemplate", fields: [checklistTemplateId], references: [id])
  assignedTo    Usuario?       @relation("AssignedServiceOrderChecklists", fields: [assignedToUserId], references: [id])
  items         ServiceOrderChecklistItem[]
  serviceOrderAttachments ServiceOrderAttachment[] @relation("ServiceOrderAttachmentsChecklist")

  @@index([companyId, serviceOrderId])
  @@index([companyId, checklistTemplateId])
  @@index([companyId, status])
  @@index([companyId, assignedToUserId])
  @@index([companyId, completedAt])
  @@index([companyId, deletedAt])
  @@map("checklists_ordem_servico")
}

model ServiceOrderChecklistItem {
  id                          String   @id @default(cuid())
  companyId                   String
  serviceOrderChecklistId     String
  checklistTemplateItemId     String?
  parentItemId                String?

  titleSnapshot               String
  descriptionSnapshot         String?
  itemTypeSnapshot            ChecklistItemType
  position                    Int
  isRequired                  Boolean @default(false)
  expectedValueSnapshot       String?
  minValueSnapshot            Decimal? @db.Decimal(12,2)
  maxValueSnapshot            Decimal? @db.Decimal(12,2)
  unitSnapshot                String?
  optionsSnapshot             Json?

  responseText                String?
  responseNumber              Decimal? @db.Decimal(12,2)
  responseBoolean             Boolean?
  responseDate                DateTime?
  responseJson                Json?
  isCompliant                 Boolean?
  technicianNotes             String?
  answeredByUserId            String?
  answeredAt                  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  company      Empresa                   @relation("ServiceOrderChecklistItemsCompany", fields: [companyId], references: [id])
  checklist    ServiceOrderChecklist     @relation(fields: [serviceOrderChecklistId], references: [id])
  templateItem ChecklistTemplateItem?    @relation("ExecutedTemplateItem", fields: [checklistTemplateItemId], references: [id])
  parentItem   ServiceOrderChecklistItem? @relation("ServiceOrderChecklistItemParent", fields: [parentItemId], references: [id])
  children     ServiceOrderChecklistItem[] @relation("ServiceOrderChecklistItemParent")
  serviceOrderAttachments ServiceOrderAttachment[] @relation("ServiceOrderAttachmentsChecklistItem")
  answeredBy   Usuario?                  @relation("AnsweredServiceOrderChecklistItems", fields: [answeredByUserId], references: [id])

  @@index([companyId, serviceOrderChecklistId])
  @@index([companyId, checklistTemplateItemId])
  @@index([serviceOrderChecklistId, position])
  @@index([companyId, answeredByUserId])
  @@index([companyId, answeredAt])
  @@index([companyId, deletedAt])
  @@map("checklist_execucao_items")
}

model ChecklistTemplate {
  id        String    @id @default(cuid())
  companyId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name        String
  description String?
  category    ChecklistCategory
  version     Int      @default(1)
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)

  company Empresa @relation("ChecklistTemplatesCompany", fields: [companyId], references: [id])
  items   ChecklistTemplateItem[]
  serviceOrderChecklists ServiceOrderChecklist[] @relation("ServiceOrderChecklistsTemplate")

  @@unique([companyId, name, version])
  @@index([companyId, category])
  @@index([companyId, isActive])
  @@index([companyId, name])
  @@index([deletedAt])
  @@map("checklist_templates")
}

model ChecklistTemplateItem {
  id                  String   @id @default(cuid())
  companyId           String
  checklistTemplateId String
  parentItemId        String?

  title       String
  description String?
  itemType    ChecklistItemType
  position    Int
  isRequired  Boolean  @default(false)
  expectedValue String?
  minValue    Decimal? @db.Decimal(12,2)
  maxValue    Decimal? @db.Decimal(12,2)
  unit        String?
  options     Json?
  helpText    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  company           Empresa              @relation("ChecklistTemplateItemsCompany", fields: [companyId], references: [id])
  checklistTemplate ChecklistTemplate    @relation(fields: [checklistTemplateId], references: [id])
  parentItem        ChecklistTemplateItem? @relation("ChecklistItemParent", fields: [parentItemId], references: [id])
  children          ChecklistTemplateItem[] @relation("ChecklistItemParent")
  executedItems     ServiceOrderChecklistItem[] @relation("ExecutedTemplateItem")

  @@index([companyId, checklistTemplateId])
  @@index([companyId, parentItemId])
  @@index([checklistTemplateId, position])
  @@index([companyId, itemType])
  @@index([companyId, deletedAt])
  @@map("checklist_template_items")
}

model Usuario {
  id        String    @id @default(cuid())
  companyId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name         String
  email        String
  passwordHash String?
  phone        String?
  role         UserRole   @default(VIEWER)
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?

  company              Empresa               @relation(fields: [companyId], references: [id])
  permissoes           Permissao[]
  equipes              Equipe[]              @relation("EquipeUsuarios")
  ordensResponsavel    OrdemServico[]        @relation("ResponsavelOS")
  agendas              Agenda[]
  notificacoes         Notificacao[]
  logs                 LogSistema[]
  arquivos             Arquivo[]
  equipmentServiceHistories EquipmentServiceHistory[]
  financialTransactionsCreated FinancialTransaction[]
  contasReceber        ContaReceber[]
  movimentacoesEstoque MovimentacaoEstoque[]
  assignedServiceOrderChecklists ServiceOrderChecklist[] @relation("AssignedServiceOrderChecklists")
  answeredServiceOrderChecklistItems ServiceOrderChecklistItem[] @relation("AnsweredServiceOrderChecklistItems")
  uploadedServiceOrderAttachments ServiceOrderAttachment[] @relation("UploadedServiceOrderAttachments")

  @@unique([companyId, email])
  @@index([companyId, status])
  @@index([companyId, role])
  @@index([deletedAt])
  @@map("usuarios")
}

model Permissao {
  id        String    @id @default(cuid())
  companyId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  userId    String
  module    String
  canRead   Boolean @default(true)
  canCreate Boolean @default(false)
  canUpdate Boolean @default(false)
  canDelete Boolean @default(false)
  canExport Boolean @default(false)

  company Empresa @relation(fields: [companyId], references: [id])
  user    Usuario @relation(fields: [userId], references: [id])

  @@unique([companyId, userId, module])
  @@index([companyId, module])
  @@index([deletedAt])
  @@map("permissoes")
}

model Cliente {
  id        String    @id @default(cuid())
  companyId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name      String
  legalName String?
  document  String?
  email     String?
  phone     String?
  type      ClientType @default(COMPANY)
  notes     String?
  active    Boolean    @default(true)

  company                Empresa                @relation(fields: [companyId], references: [id])
  enderecos              Endereco[]
  equipamentosInstalados EquipamentoInstalado[]
  ordensServico          OrdemServico[]
  agendas                Agenda[]
  financeiros            Financeiro[]
  contasReceber          ContaReceber[]
  orcamentos             Orcamento[]
  contratos              Contrato[]
  manutencoesPreventivas ManutencaoPreventiva[]
  financialTransactions FinancialTransaction[]
  arquivos               Arquivo[]
  serviceOrderAcceptances ServiceOrderAcceptance[] @relation("ServiceOrderAcceptancesClient")
  warranties             Warranty[]              @relation("ClientWarranties")

  @@unique([companyId, document])
  @@index([companyId, name])
  @@index([companyId, active])
  @@index([deletedAt])
  @@map("clientes")
}

model Endereco {
  id        String    @id @default(cuid())
  companyId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  clientId   String?
  type       AddressType @default(SERVICE)
  street     String
  number     String?
  complement String?
  district   String?
  city       String
  state      String
  zipCode    String?
  country    String      @default("Brasil")
  latitude   Decimal?    @db.Decimal(10, 7)
  longitude  Decimal?    @db.Decimal(10, 7)

  company Empresa        @relation(fields: [companyId], references: [id])
  cliente Cliente?       @relation(fields: [clientId], references: [id])
  ordens  OrdemServico[]
  agendas Agenda[]

  @@index([companyId, clientId])
  @@index([companyId, city, state])
  @@index([deletedAt])
  @@map("enderecos")
}

model Equipamento {
  id        String    @id @default(cuid())
  companyId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name        String
  brand       String?
  model       String?
  category    String?
  description String?
  active      Boolean @default(true)

  company    Empresa                @relation(fields: [companyId], references: [id])
  instalados EquipamentoInstalado[]

  @@index([companyId, name])
  @@index([companyId, category])
  @@index([deletedAt])
  @@map("equipamentos")
}

model EquipamentoInstalado {
  id        String    @id @default(cuid())
  companyId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  clientId      String
  equipmentId   String
  serialNumber  String?
  assetTag      String?
  location      String?
  installedAt   DateTime?
  warrantyUntil DateTime?
  status        String    @default("ACTIVE")
  notes         String?

  company                Empresa                @relation(fields: [companyId], references: [id])
  cliente                Cliente                @relation(fields: [clientId], references: [id])
  equipamento            Equipamento            @relation(fields: [equipmentId], references: [id])
  ordensServico          OrdemServico[]
  manutencoesPreventivas ManutencaoPreventiva[]
  serviceHistories       EquipmentServiceHistory[]
  warranties             Warranty[]              @relation("EquipmentWarrantiesInstalledEquipment")

  @@unique([companyId, serialNumber])
  @@index([companyId, clientId])
  @@index([companyId, equipmentId])
  @@index([deletedAt])
  @@map("equipamentos_instalados")
}

enum EquipmentHistoryEventType {
  INSTALLATION
  PREVENTIVE_MAINTENANCE
  CORRECTIVE_MAINTENANCE
  CLEANING
  INSPECTION
  DIAGNOSIS
  PART_REPLACEMENT
  REFRIGERANT_CHARGE
  ELECTRICAL_REPAIR
  CALIBRATION
  WARRANTY_SERVICE
  REMOVAL
  REPLACEMENT
  STATUS_CHANGE
  OTHER
}

model EquipmentServiceHistory {
  id                    String   @id @default(cuid())
  companyId             String
  installedEquipmentId  String
  serviceOrderId        String?
  technicianUserId      String?

  eventType             EquipmentHistoryEventType
  title                 String
  description           String?
  serviceDate           DateTime
  operatingHours        Decimal? @db.Decimal(12,2)
  odometerReading       Decimal? @db.Decimal(12,2)
  previousStatus        String?
  resultingStatus       String?
  diagnosis             String?
  solution              String?
  recommendations       String?
  measurements          Json?
  partsReplaced         String?
  refrigerantAdded      Decimal? @db.Decimal(12,2)
  refrigerantType       String?
  pressureLowSide       Decimal? @db.Decimal(8,2)
  pressureHighSide      Decimal? @db.Decimal(8,2)
  inputVoltage          Decimal? @db.Decimal(8,2)
  currentDraw           Decimal? @db.Decimal(8,2)
  temperatureBefore     Decimal? @db.Decimal(6,2)
  temperatureAfter      Decimal? @db.Decimal(6,2)
  warrantyUntil         DateTime?
  nextRecommendedServiceDate DateTime?
  customerSignatureName String?
  notes                 String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  deletedAt             DateTime?

  company               Empresa  @relation(fields: [companyId], references: [id])
  installedEquipment    EquipamentoInstalado @relation(fields: [installedEquipmentId], references: [id])
  ordemServico          OrdemServico? @relation(fields: [serviceOrderId], references: [id])
  technician            Usuario? @relation(fields: [technicianUserId], references: [id])

  @@index([companyId, installedEquipmentId])
  @@index([companyId, serviceDate])
  @@index([companyId, eventType])
  @@index([companyId, serviceOrderId])
  @@index([companyId, technicianUserId])
  @@index([companyId, nextRecommendedServiceDate])
  @@index([companyId, deletedAt])
  @@map("historicos_equipamentos_instalados")
}

model Fornecedor {
  id        String    @id @default(cuid())
  companyId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name     String
  document String?
  email    String?
  phone    String?
  category String?
  active   Boolean @default(true)

  company     Empresa      @relation(fields: [companyId], references: [id])
  produtos    Produto[]
  contasPagar ContaPagar[]
  financialTransactions FinancialTransaction[]

  @@unique([companyId, document])
  @@index([companyId, name])
  @@index([deletedAt])
