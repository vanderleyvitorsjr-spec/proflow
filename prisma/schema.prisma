  @@index([companyId, isDefault])
  @@index([companyId, deletedAt])
  @@map("categorias_financeiras")

  financialTransactions FinancialTransaction[]
}

model FinancialAccount {
  id                 String    @id @default(cuid())
  companyId          String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  name               String
  accountType        AccountType
  bankName           String?
  initialBalance     Decimal   @default(0) @db.Decimal(12, 2)
  initialBalanceDate DateTime
  isDefault          Boolean   @default(false)
  isActive           Boolean   @default(true)

  company Empresa @relation(fields: [companyId], references: [id])

  @@index([companyId, accountType])
  @@index([companyId, isDefault])
  @@index([companyId, deletedAt])
  @@map("contas_financeiras")

  financialTransactions FinancialTransaction[]
  contasReceber        ContaReceber[]
}

enum TransactionStatus {
  PLANNED
  PENDING
  PARTIALLY_PAID
  PAID
  OVERDUE
  RENEGOTIATED
  CANCELED
  REVERSED
}

enum PaymentMethod {
  PIX
  CASH
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  BOLETO
  CHECK
  PAYMENT_LINK
  OTHER
}

model FinancialTransaction {
  id                 String             @id @default(cuid())
  companyId          String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?

  financialCategoryId String
  financialAccountId  String
  clientId            String?
  serviceOrderId      String?
  supplierId          String?
  createdById         String

  description         String
  amount              Decimal            @db.Decimal(12, 2)
  transactionType     TransactionType
  status              TransactionStatus
  paymentMethod       PaymentMethod?
  competenceDate      DateTime
  dueDate             DateTime?
  paidAt              DateTime?
  notes               String?

  company             Empresa            @relation(fields: [companyId], references: [id])
  financialCategory   FinancialCategory  @relation(fields: [financialCategoryId], references: [id])
  financialAccount    FinancialAccount   @relation(fields: [financialAccountId], references: [id])
  cliente             Cliente?           @relation(fields: [clientId], references: [id])
  contasReceber       ContaReceber[]
  ordemServico        OrdemServico?      @relation(fields: [serviceOrderId], references: [id])
  fornecedor          Fornecedor?        @relation(fields: [supplierId], references: [id])
  createdBy           Usuario            @relation(fields: [createdById], references: [id])

  @@index([companyId, financialCategoryId])
  @@index([companyId, financialAccountId])
  @@index([companyId, clientId])
  @@index([companyId, serviceOrderId])
  @@index([companyId, supplierId])
  @@index([companyId, transactionType])
  @@index([companyId, status])
  @@index([companyId, competenceDate])
  @@index([companyId, dueDate])
  @@index([companyId, paidAt])
  @@index([companyId, deletedAt])
  @@map("transacoes_financeiras")
}

model ConfiguracaoEmpresa {
  id        String    @id @default(cuid())
  companyId String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  timezone     String  @default("America/Sao_Paulo")
  currency     String  @default("BRL")
  locale       String  @default("pt-BR")
  logoUrl      String?
  primaryColor String  @default("#2563eb")
  settings     Json?

  company Empresa @relation(fields: [companyId], references: [id])

  @@index([deletedAt])
  @@map("configuracoes_empresa")
}
